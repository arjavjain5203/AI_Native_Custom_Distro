# ──────────────────────────────────────────────
# AI-Native Developer Operating Environment
# Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# ── GitHub Integration ──
GITHUB_TOKEN=

# ── Ollama Configuration ──
OLLAMA_HOST=http://127.0.0.1:11434

# ── Daemon Settings ──
AI_OS_API_HOST=127.0.0.1
AI_OS_API_PORT=8000

# ── Model Assignments ──
AI_OS_INTENT_MODEL=phi3:mini
AI_OS_PLANNING_MODEL=gemma:2b
AI_OS_CODING_MODEL=qwen2.5-coder:1.5b
AI_OS_ANALYSIS_MODEL=gemma:2b

# ── Model Runtime ──
# Options: auto, ollama, airllm
AI_OS_MODEL_RUNTIME=auto

# ── Memory ──
AI_OS_MEMORY_DB=ai_core.db
